    <ItemGroup>
      <Folder Include="Models" />
      <Folder Include="obj\Debug\net8.0" />
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="DotNetEnv" Version="3.1.1" />
      <PackageReference Include="log4net" Version="3.0.4" />
      <PackageReference Include="Npgsql" Version="9.0.3" />
